  },
  "bugs": {
    "url": "https://github.com/MiguelRipoll23/homebridge-securitysystem/issues"
  },
  "keywords": [
    "homebridge-plugin",
    "homebridge",
    "homekit",
    "security system",
    "alarm",
    "category-security"
  ],
  "main": "dist/index.js",
  "engines": {
    "node": "^22 || ^24",
    "homebridge": "^1.8.0 || ^2.0.0"
  },
  "scripts": {
