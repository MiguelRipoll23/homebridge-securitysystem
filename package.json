    "mqtt": "^5.15.1",
    "node-persist": "^4.0.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "@types/node-persist": "^3.1.8",
    "eslint": "^10.5.0",
    "homebridge": "^2.1.0",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "funding": [
