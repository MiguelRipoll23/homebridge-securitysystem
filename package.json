{
  "name": "homebridge-securitysystem",
  "displayName": "Homebridge Security System",
  "type": "module",
  "version": "10.1.0",
  "description": "Homebridge plugin that creates a security system accessory that can be triggered by HomeKit sensors.",
  "author": "MiguelRipoll23",
  "license": "MIT",
  "homepage": "https://github.com/MiguelRipoll23/homebridge-securitysystem#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/MiguelRipoll23/homebridge-securitysystem.git"
  },
  "bugs": {
    "url": "https://github.com/MiguelRipoll23/homebridge-securitysystem/issues"
  },
  "keywords": [
    "homebridge-plugin",
    "homebridge",
    "homekit",
    "security system",
    "alarm",
    "category-security"
  ],
  "main": "dist/index.js",
  "engines": {
    "node": "^20.18.0 || ^22.10.0 || ^24.0.0",
    "homebridge": "^1.8.0 || ^2.0.0"
